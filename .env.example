PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=shoes_store

# JWT
JWT_SECRET=your_super_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# Admin credentials
ADMIN_EMAIL=admin@shoescart.com
ADMIN_PASSWORD=strongpassword

# Logging
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=info
